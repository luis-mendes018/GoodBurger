@page "/pedidos/create"

<div class="container mt-4">

    <h3 class="fw-bold mb-4">Novo Pedido</h3>

    <EditForm Model="vm" OnValidSubmit="CreateOrder">

        <DataAnnotationsValidator />
        <ValidationSummary />
        <!-- CLIENTE -->
        <div class="mb-3">
            <label class="form-label">Nome do Cliente</label>
            <input class="form-control"
                   @bind="vm.NameClient" />
        </div>
        @if (vm.Products.Count == 0)
        {
            <div class="text-center mt-4">
                <div class="spinner-border"></div>
            </div>
        }
        else
        {
            <!-- SANDUÍCHES -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header fw-bold">Sanduíche</div>
                <div class="card-body">

                    @foreach (var p in vm.Products.Where(p => p.Type == "Sandwich"))
                    {
                        <div class="form-check">
                            <input type="checkbox"
                                   class="form-check-input"
                                   @bind="p.IsSelected" />

                            <label class="form-check-label">
                                @p.Name (R$ @p.Price)
                            </label>
                        </div>
                    }

                </div>
            </div>

            <!-- ACOMPANHAMENTOS -->
            <div class="card mb-3 shadow-sm">
                <div class="card-header fw-bold">Acompanhamentos</div>
                <div class="card-body">

                    @foreach (var p in vm.Products.Where(p => p.Type == "Side"))
                    {
                        <div class="form-check">
                            <input type="checkbox"
                                   class="form-check-input"
                                   @bind="p.IsSelected" />

                            <label class="form-check-label">
                                @p.Name (R$ @p.Price)
                            </label>
                        </div>
                    }

                </div>
            </div>

            <!-- BOTÕES -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    Criar Pedido
                </button>

                <button class="btn btn-secondary"
                        @onclick="Voltar">
                    Cancelar
                </button>
            </div>

        }
    </EditForm>

    @if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-danger mt-3">
            @error
        </div>
    }

</div>

@code {
    private CreateOrderViewModel vm = new();
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        var menu = await Http.GetFromJsonAsync<MenuViewModel>("v1/menu");

        if (menu is null) return;

        vm.Products = [
            ..menu.Sandwiches.Select(p => new ProductOption
            {
                Id = p.Id,
                Name = p.Name,
                Price = p.Price,
                Type = "Sandwich"
            }),
            ..menu.Sides.Select(p => new ProductOption
            {
                Id = p.Id,
                Name = p.Name,
                Price = p.Price,
                Type = "Side"
            })
        ];
    }

    private async Task CreateOrder()
    {
        vm.SelectedProductIds = vm.Products
            .Where(p => p.IsSelected)
            .Select(p => p.Id)
            .ToList();

        var response = await Http.PostAsJsonAsync("v1/orders/post", new
        {
            nameClient = vm.NameClient,
            productIds = vm.SelectedProductIds
        });

        if (!response.IsSuccessStatusCode)
        {
            var err = await response.Content.ReadFromJsonAsync<ApiError>();

            error = err?.Message ?? "Erro ao criar pedido";
            return;
        }

        Nav.NavigateTo("/pedidos");
    }

    private void Voltar()
    {
        Nav.NavigateTo("/pedidos");
    }

    [Inject] public HttpClient Http { get; set; } = default!;
    [Inject] public NavigationManager Nav { get; set; } = default!;

    public class ApiError
    {
        public string Error { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
}
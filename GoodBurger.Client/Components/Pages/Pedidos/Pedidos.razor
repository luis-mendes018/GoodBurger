@page "/pedidos"

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Pedidos</h3>

        <button class="btn btn-success shadow-sm"
                @onclick="NovoPedido">
            + Novo Pedido
        </button>
    </div>

    <!-- BUSCA -->
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex gap-2 align-items-center">

            <input class="form-control"
                   placeholder="Buscar cliente..."
                   @bind="search" />

            <button class="btn btn-primary"
                    @onclick="LoadOrders">
                Buscar
            </button>

            <button class="btn btn-outline-secondary"
                    @onclick="ClearSearch">
                Limpar
            </button>

        </div>
    </div>

    @if (orders == null)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Carregando pedidos...</p>
        </div>
    }
    else
    {
        <!-- TOTAL -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted">
                Exibindo <strong>@orders.Data.Count</strong> de <strong>@orders.TotalItems</strong> pedidos
            </span>

            <span class="badge bg-dark fs-6">
                Total: @orders.TotalItems
            </span>
        </div>

        <!-- TABELA -->
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">

                <thead class="table-dark">
                    <tr>
                        <th>Cliente</th>
                        <th>Total</th>
                        <th class="text-end">Opções</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var o in orders.Data)
                    {
                        <tr>
                            <td class="fw-semibold">@o.NameClient</td>

                            <td>
                                <span class="badge bg-success fs-6">
                                    R$ @o.Total.ToString("0.00")
                                </span>
                            </td>

                            <td class="text-end">
                                <div class="btn-group">

                                    <button class="btn btn-outline-info btn-sm"
                                            @onclick="() => VerDetalhes(o.Id)">
                                        👁
                                    </button>

                                    <button class="btn btn-outline-primary btn-sm"
                                            @onclick="() => Editar(o.Id)">
                                        ✏️
                                    </button>

                                    <button class="btn btn-outline-danger btn-sm"
                                            @onclick="() => ConfirmarDelete(o.Id)">
                                        🗑
                                    </button>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

        <!-- PAGINAÇÃO -->
        <div class="d-flex justify-content-between align-items-center mt-4">

            <button class="btn btn-outline-primary"
                    disabled="@(currentPage == 1)"
                    @onclick="PrevPage">
                ← Anterior
            </button>

            <span class="fw-semibold">
                Página @currentPage de @TotalPages
            </span>

            <button class="btn btn-outline-primary"
                    disabled="@(currentPage >= TotalPages)"
                    @onclick="NextPage">
                Próxima →
            </button>

        </div>
    }
</div>

@code {
    private string? search;
    private PagedResponse<OrderResponseViewModel>? orders;

    private int currentPage = 1;
    private int pageSize = 4;

    private int TotalPages =>
        orders == null
            ? 1
            : (int)Math.Ceiling((double)orders.TotalItems / pageSize);

    private OrderDetailViewModel? selectedOrder;

    private bool showDeleteModal;
    private bool showDetailModal;

    private Guid idToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        orders = await Http.GetFromJsonAsync<PagedResponse<OrderResponseViewModel>>(
            $"v1/orders/search?name={search}&page={currentPage}&pageSize={pageSize}");
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadOrders();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            await LoadOrders();
        }
    }

    private async Task ClearSearch()
    {
        search = null;
        currentPage = 1;
        await LoadOrders();
    }

    private void NovoPedido()
    {
        Nav.NavigateTo("/pedidos/create");
    }

    private void Editar(Guid id)
    {
        Nav.NavigateTo($"/pedidos/edit/{id}");
    }

    private async Task VerDetalhes(Guid id)
    {
        selectedOrder = await Http.GetFromJsonAsync<OrderDetailViewModel>($"v1/orders/{id}");
        showDetailModal = true;
    }

    private void ConfirmarDelete(Guid id)
    {
        idToDelete = id;
        showDeleteModal = true;
    }

    private async Task Delete()
    {
        await Http.DeleteAsync($"v1/orders/delete/{idToDelete}");
        showDeleteModal = false;
        await LoadOrders();
    }

    [Inject] public HttpClient Http { get; set; } = default!;
    [Inject] public NavigationManager Nav { get; set; } = default!;
}

@if (showDetailModal && selectedOrder != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Detalhes do Pedido</h5>
                </div>

                <div class="modal-body">
                    <p><strong>Cliente:</strong> @selectedOrder.NameClient</p>
                    <p><strong>Data:</strong> @selectedOrder.CreatedAtFormatted</p>

                    <hr />

                    <h6>Itens</h6>
                    <ul>
                        @foreach (var item in selectedOrder.Items)
                        {
                            <li>@item.ProductName - R$ @item.UnitPrice</li>
                        }
                    </ul>

                    <hr />

                    <p><strong>Subtotal:</strong> R$ @selectedOrder.Subtotal</p>
                    <p><strong>Desconto:</strong> R$ @selectedOrder.Discount</p>
                    <p><strong>Total:</strong> R$ @selectedOrder.Total</p>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showDetailModal = false">Fechar</button>
                </div>

            </div>
        </div>
    </div>
}

@if (showDeleteModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content shadow">

                <div class="modal-header bg-danger text-white">
                    <h5 class="mb-0">Confirmar exclusão</h5>
                </div>

                <div class="modal-body">
                    Tem certeza que deseja excluir este pedido?
                </div>

                <div class="modal-footer">
                    <button class="btn btn-danger" @onclick="async () => await Delete()">
                        Excluir
                    </button>

                    <button class="btn btn-secondary"
                            @onclick="() => showDeleteModal = false">
                        Cancelar
                    </button>
                </div>

            </div>
        </div>
    </div>
}
@page "/menu"

<h2 class="mb-4 text-center fw-bold">Cardápio</h2>
<br />
@if (menu is null)
{
    <div class="text-center mt-5">
        <div class="spinner-border" role="status"></div>
        <p class="mt-2">Carregando...</p>
    </div>
}
else
{
    <div class="row">
        <!-- Sanduíches -->
        <div class="col-md-6">
            <h4 class="mb-3">🥪 Sanduíches</h4>

            @foreach (var item in menu.Sandwiches)
            {
                <div class="card mb-3 shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@item.Name</strong>
                        </div>
                        <span class="badge bg-success fs-6">
                            R$ @item.Price
                        </span>
                    </div>
                </div>
            }
        </div>

        <!-- Acompanhamentos -->
        <div class="col-md-6">
            <h4 class="mb-3">🍟 Acompanhamentos</h4>

            @foreach (var item in menu.Sides)
            {
                <div class="card mb-3 shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@item.Name</strong>
                        </div>
                        <span class="badge bg-primary fs-6">
                            R$ @item.Price
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private MenuViewModel? menu;

    protected override async Task OnInitializedAsync()
    {
        var result = await Http.GetFromJsonAsync<MenuViewModel>("v1/menu");

        if (result is not null)
        {
            menu = result;
        }
    }

    [Inject] public HttpClient Http { get; set; } = default!;
}